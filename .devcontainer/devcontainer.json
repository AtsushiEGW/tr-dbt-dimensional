{
  "name": "dimensional modeling container (playwright-official)",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "app",
  "workspaceFolder": "/workspace/project",
  "shutdownAction": "stopCompose",

  "overrideCommand": false,

  "forwardPorts": [55432, 3000, 6080],
  "remoteUser": "pwuser",

  "mounts": [
    "source=${localEnv:HOME}/.dotfiles,target=/home/pwuser/.dotfiles,type=bind,consistency=cached,readonly"
  ],
  "postStartCommand": "bash -lc '~/.dotfiles/bootstrap.sh || true'",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic",
        "python.analysis.autoSearchPaths": true,
        "python.analysis.useLibraryCodeForTypes": true,
        "python.formatting.provider": "black",
        "editor.formatOnSave": true,
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
            "zsh": {
                "path": "/usr/bin/zsh"
            }
        },
      }
    }
  }
}